{
  "name": "example-api-ts-express",
  "version": "1.0.0",
  "private": true,
  "description": "Example API — Node/TypeScript + Express + Prisma implementation.",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate --accept-data-loss",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
