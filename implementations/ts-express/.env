# Local/dev + build convenience only. In Docker these are supplied by docker-compose.yml
# (this file is excluded from the image via .dockerignore). Not a source of real secrets.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exampleapi?schema=public"
PORT=8080
JWT_SECRET="CHANGE-THIS-IN-PRODUCTION-use-a-long-random-secret-key"
JWT_ISSUER="ExampleApi"
JWT_AUDIENCE="ExampleApiClient"
JWT_EXPIRATION_MINUTES=60
